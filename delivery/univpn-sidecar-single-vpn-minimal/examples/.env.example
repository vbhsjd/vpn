VPN_SERVER=your.vpn.server
VPN_PORT=443
VPN_USER=change-me
VPN_PASSWORD=change-me
VPN_PROFILE_NAME=office
UNIVPN_CONNECT_TIMEOUT=120
UNIVPN_READY_POLL_INTERVAL=1
UNIVPN_MENU_SCAN_TIMEOUT=2
UNIVPN_PROFILE_SETTLE_SECONDS=2
UNIVPN_IMPORTED_PROFILE_SETTLE_SECONDS=0
UNIVPN_AUTOGENERATE_PROFILE=true
UNIVPN_BOOTSTRAP_PROFILE=true
UNIVPN_REQUIRE_TUN=true
# Optional fast path: set either VPN_CONFIG_PATH or VPN_CONFIG_B64 instead of bootstrapping.
# Use a real exported profile here. office.ini.example only documents the file format.
# VPN_CONFIG_PATH=/usr/local/UniVPN/config/office.ini
# VPN_CONFIG_B64=
